---
// src/pages/projects/insultrack.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout title="InsulTrack Ecosystem | Ean Cummings">
  <article class="project-deep-dive animate-fade-in">
    
    <!-- ==================== 1. CINEMATIC HEADER ==================== -->
    <header class="project-hero">
      <div class="project-hero-container">
        <span class="pro-tag-badge">Biomedical Consumer Tech</span>
        <h1 class="pro-headline">InsulTrack</h1>
        <p class="pro-subheading">
          A thermally insulated, sensor-embedded management casing for diabetic insulin supply bridging hardware thermal regulation with a native iOS tracking ecosystem.
        </p>
      </div>
      <div class="grid-overlay"></div>
    </header>

    <!-- ==================== AWARD BANNER SECTION ==================== -->
    <section class="award-banner">
      <div class="award-container">
        <svg class="award-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        <p class="award-text">
          <strong>Award:</strong> 3rd Place, Hubert E. Storer Engineering Student Entrepreneurial Start-Up Award
        </p>
      </div>
    </section>

    <!-- ==================== 2. HARDWARE & THERMAL DESIGN ==================== -->
    <section class="pro-content-row">
      <div class="pro-sidebar">
        <span class="row-num">01 / Hardware</span>
        <h2>Thermal Preservation & Protection</h2>
      </div>
      
      <div class="pro-main-body">
        <p>
          To ensure optimal insulin potency, the medication temperature must remain strictly between 59 and 86 degrees Fahrenheit. Current market solutions lack the thermal regulation required to prevent denaturing in harsh external environments.
        </p>
        <p>
          To solve this, InsulTrack utilizes an advanced aerogel insulation layer housed within a modular, cylindrical hard-shell form factor designed to fit standard insulin pens. The casing is engineered to meet IP67 dust and water resistance standards and survive 1.5-meter kinetic impacts, ensuring fragile glass components remain protected.
        </p>
        
        <!-- Premium Dual Photo Showcase Grid -->
        <div class="product-media-gallery">
          <div class="media-panel-box">
            <img src="/images/insultrack-app.png" alt="InsulTrack Native iOS Application Dashboard" class="media-photo" />
            <span class="media-caption">Native iOS dashboard aggregating continuous blood glucose data, insulin dosages, and meal timing.</span>
          </div>
          <div class="media-panel-box">
            <img src="/images/insultrack-shot.png" alt="InsulTrack Physical Hardware Prototype" class="media-photo" />
            <span class="media-caption">Physical hardware prototype featuring the integrated OLED screen, ESP32 micro-architecture, and aerogel thermal core.</span>
          </div>
        </div>

      </div>
    </section>

    <!-- ==================== 3. SOFTWARE & ECOSYSTEM ==================== -->
    <section class="pro-content-row">
      <div class="pro-sidebar">
        <span class="row-num">02 / Ecosystem</span>
        <h2>CoreBluetooth & iOS Integration</h2>
      </div>
      
      <div class="pro-main-body">
        <p>
          A physical case is only half of the solution; patients require peace of mind regarding their medication history and location. The InsulTrack hardware interfaces directly with a custom native iOS application written entirely in Swift.
        </p>
        <p>
          An onboard Adafruit ESP32 microcontroller and OLED Feather screen allow users to interact with the device and log dosages directly on the casing. This data synchronizes to the user's phone via CoreBluetooth (BLE). The mobile app aggregates this injection data alongside continuous blood glucose levels, sleep metrics, and workout routines to provide a unified, patient-centered health management platform.
        </p>
      </div>
    </section>

    <!-- ==================== 4. TECH SPECS DASHBOARD ==================== -->
    <section class="pro-content-row border-top-only">
      <div class="pro-sidebar">
        <span class="row-num">03 / Tech Specs</span>
        <h2>System Specifications</h2>
      </div>
      
      <div class="pro-main-body">
        <div class="specs-mini-grid">
          <div class="spec-mini-card">
            <h4>Processor & Display</h4>
            <p>Adafruit ESP32 with OLED Feather Screen</p>
          </div>
          <div class="spec-mini-card">
            <h4>Thermal Core</h4>
            <p>High-efficiency Aerogel insulation layer</p>
          </div>
          <div class="spec-mini-card">
            <h4>Location Tracking</h4>
            <p>Native Apple Find My Network integration</p>
          </div>
          <div class="spec-mini-card">
            <h4>Software Stack</h4>
            <p>Swift iOS Application, CoreBluetooth Syncing</p>
          </div>
        </div>
      </div>
    </section>

  </article>
</Layout>

<!-- ==================== STYLES ==================== -->
<style>
  .project-deep-dive {
    max-width: 1024px;
    width: min(100%, 92%);
    margin: 0 auto;
    padding: 80px 0;
  }

  /* --- Advanced Hero Styling Layering --- */
  .project-hero {
    min-height: 50vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding-top: 80px;
    padding-bottom: 60px;
    background-color: #000000;
  }

  /* Using a pseudo-element layers the photo underneath the grid overlay */
  .project-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.4) 0%, rgba(0, 0, 0, 0.75) 65%, #000000 92%, #000000 100%), url('/images/insultrack-bg.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index: 1;
  }

  .project-hero-container {
    position: relative;
    z-index: 10;
    padding: 0 4px;
  }

  .pro-tag-badge {
    display: inline-block;
    padding: 4px 12px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--accent-blue);
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(47, 128, 237, 0.4);
    border-radius: 100px;
    text-transform: uppercase;
    margin-bottom: 20px;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .pro-headline {
    font-size: 4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 20px 0;
    color: #ffffff;
    /* Added drop shadow layer to lift text off your photo background */
    text-shadow: 0 4px 24px rgba(0, 0, 0, 0.75), 0 2px 4px rgba(0, 0, 0, 0.5);
  }

  .pro-subheading {
    font-size: 1.35rem;
    color: #e8e8ed;
    max-width: 720px;
    font-weight: 400;
    line-height: 1.5;
    margin: 0;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.8);
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 32px 32px;
    pointer-events: none;
    z-index: 2; /* Sits cleanly between image and text layout container */
  }

  /* --- Award Banner Layout --- */
  .award-banner {
    position: relative;
    z-index: 10;
    background: linear-gradient(90deg, rgba(212, 175, 55, 0.03) 0%, rgba(212, 175, 55, 0.08) 50%, rgba(212, 175, 55, 0.03) 100%);
    border: 1px solid rgba(212, 175, 55, 0.15);
    border-radius: 12px;
    padding: 16px 24px;
    margin-top: 10px;
    margin-bottom: 24px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  .award-container {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .award-icon {
    width: 20px;
    height: 20px;
    color: #d4af37;
    flex-shrink: 0;
    filter: drop-shadow(0 0 8px rgba(212, 175, 55, 0.4));
  }

  .award-text {
    margin: 0;
    font-size: 13px;
    color: var(--text-apple);
    font-weight: 400;
    line-height: 1.4;
  }

  .award-text strong {
    color: #d4af37;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* --- Row Layout Mechanics --- */
  .pro-content-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    padding: 64px 0;
    border-bottom: 1px solid var(--border-color);
    align-items: start;
  }

  .border-top-only {
    border-bottom: none;
  }

  @media (min-width: 768px) {
    .pro-content-row {
      grid-template-columns: 3fr 5fr;
      gap: 64px;
    }
    .pro-sidebar {
      position: sticky;
      top: 100px;
    }
  }

  .row-num {
    font-family: monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .pro-sidebar h2 {
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-top: 8px;
    margin-bottom: 0;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .pro-main-body {
    font-size: 15px; /* Bumped up readability scale slightly */
    color: var(--text-secondary);
    font-weight: 300;
    line-height: 1.7;
  }
  .pro-main-body p {
    margin-top: 0;
    margin-bottom: 20px;
  }

  /* --- Upgraded Dual Photo Showcase Grid --- */
  .product-media-gallery {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-top: 32px;
    width: 100%;
  }

  @media (min-width: 640px) {
    .product-media-gallery {
      grid-template-columns: 1fr 1fr;
    }
  }

  .media-panel-box {
    background: #0d0d0e;
    border: 1px solid var(--border-color);
    border-radius: 14px;
    padding: 8px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    display: flex;
    flex-direction: column;
  }

  .media-photo {
    width: 100%;
    max-height: 240px; 
    object-fit: cover; 
    object-position: top center; 
    border-radius: 8px;
    display: block;
  }

  .media-caption {
    display: block;
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 10px;
    padding: 0 4px;
    text-align: left;
    font-weight: 300;
    line-height: 1.4;
  }

  /* --- Technical Spec Breakdown --- */
  .specs-mini-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 16px;
  }

  .spec-mini-card {
    background: rgba(255, 255, 255, 0.01);
    border: 1px solid var(--border-color);
    padding: 20px;
    border-radius: 12px;
  }

  .spec-mini-card h4 {
    margin: 0 0 6px 0;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .spec-mini-card p {
    margin: 0;
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.4;
  }
</style>